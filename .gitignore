# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/

# Model files (large binaries — track metrics.json instead)
results/**/*.zip

# Per-step logs (can be large — regenerate by rerunning experiment)
results/**/steps.csv

# PyBullet temp files
*.bullet

# Logs
*.log

# Generated plots (regenerate with plot.py)
results/**/*.png

# RunPod venv
drone-venv/

# Weights & Biases (if enabled later)
wandb/

# Large checkpoint files (keep in results/ but ignore loose ones)
*.ckpt

# SSH keys (NEVER commit these)
ssh_key_runpod
ssh_key_runpod.pub

# Claude Code local settings (contains HF_TOKEN — NEVER commit)
.claude/settings.local.json

# OS
.DS_Store
Thumbs.db
ssh_key_runpod
ssh_key_runpod.pub
